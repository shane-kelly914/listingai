{
  "expo": {
    "name": "ListingAI",
    "slug": "listingai",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "listingai",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.listingai.app",
      "requireFullScreen": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#111e2d",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.listingai.app"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#111e2d"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow ListingAI to access your photos",
          "cameraPermission": "Allow ListingAI to access your camera"
        }
      ],
      [
        "expo-av",
        {
          "microphonePermission": "Allow ListingAI to access your microphone"
        }
      ],
      "expo-secure-store"
    ]
  }
}
